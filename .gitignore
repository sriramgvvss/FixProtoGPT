# Base FIX specs (large XML/spec files, ~47 MB)
Base_Fix_Specs/

# Logs — exclude entire directory
logs/

# Documentation — only keep the two writeups
documentation/*
!documentation/writeups/
documentation/writeups/*
!documentation/writeups/AI_MODEL_DEEP_DIVE.md
!documentation/writeups/OVERVIEW.md

# PID files (process management)
pids/

# SQLite databases (per-env, never committed)
db/

