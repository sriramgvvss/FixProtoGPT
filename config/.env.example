# ============================================================
# FixProtoGPT — Environment Variable Reference
# ============================================================
# Copy this file or use the pre-built profiles in config/env/.
#
# Usage:
#   export FIXPROTOGPT_ENV=dev        # selects config/env/.env.dev
#   export FIXPROTOGPT_ENV=prod       # selects config/env/.env.prod
#
# The matching .env file is loaded automatically.  Any variable
# already set in the OS environment takes precedence over the file.
# ============================================================

# ── Environment selector ────────────────────────────────────
# Valid values: dev, qa, preprod, prod
FIXPROTOGPT_ENV=dev

# ── Security ────────────────────────────────────────────────
# Flask secret key for session signing.
# REQUIRED in prod/preprod — the app will refuse to start
# with the dev default.  Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
FIXPROTOGPT_SECRET_KEY=fixprotogpt-dev-secret-change-in-prod

# ── Debug ───────────────────────────────────────────────────
# Enable Flask debug mode (Werkzeug debugger + auto-reload).
# NEVER true in production.
FIXPROTOGPT_DEBUG=true

# ── Session / Cookies ──────────────────────────────────────
FIXPROTOGPT_SESSION_COOKIE_SECURE=false
FIXPROTOGPT_SESSION_COOKIE_HTTPONLY=true
FIXPROTOGPT_SESSION_COOKIE_SAMESITE=Lax
FIXPROTOGPT_SESSION_LIFETIME=86400

# ── Demo Data ──────────────────────────────────────────────
# Seed default users (admin/trader/developer) on first run.
# Disable for qa/preprod/prod.
FIXPROTOGPT_SEED_DEMO_USERS=true

# ── CORS ───────────────────────────────────────────────────
# Comma-separated allowed origins.  Empty = allow all (dev only).
FIXPROTOGPT_CORS_ORIGINS=

# ── Logging ────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR, CRITICAL
FIXPROTOGPT_LOG_LEVEL=INFO

# ── Server ─────────────────────────────────────────────────
FIXPROTOGPT_HOST=0.0.0.0
FIXPROTOGPT_PORT=8080

# ── Security Headers ──────────────────────────────────────
# Content-Security-Policy header value
FIXPROTOGPT_CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'

# HTTP Strict Transport Security (enable only when HTTPS is active)
FIXPROTOGPT_HSTS_ENABLED=false
FIXPROTOGPT_HSTS_MAX_AGE=31536000

# ── External APIs ─────────────────────────────────────────
# Twelve Data API key for live market symbol resolution
# TWELVE_DATA_API_KEY=your-key-here
